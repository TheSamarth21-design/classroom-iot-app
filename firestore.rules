rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Any authenticated user can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Only admins can query/list the users collection (for Manage Admins screen)
      allow list: if isAdmin();
      
      // Only admins can update user profiles/roles
      allow update: if isAdmin();
      
      // Allow creation during signup
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms collection
    match /Classrooms/{classroomId} {
      allow read: if request.auth != null;
      
      // Only admins can create or delete classrooms
      allow create, delete: if isAdmin();

      // Admins can update anything.
      // Authenticated users can ONLY update the 'states' field (for toggling switches).
      allow update: if isAdmin() || (
        request.auth != null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['states'])
      );
      
      // Switches subcollection
      match /switches/{switchId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }
  }
}
