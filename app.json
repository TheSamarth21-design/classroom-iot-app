{
  "expo": {
    "name": "ClassControl",
    "slug": "classroom-iot-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "classcontrol",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.classcontrol.app"
    },
    "android": {
      "package": "com.classcontrol.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "122384a9-1773-45fc-aa13-606b75601066"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/122384a9-1773-45fc-aa13-606b75601066"
    }
  }
}
